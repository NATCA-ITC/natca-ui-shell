{
  "name": "@natca-itc/ui-shell",
  "version": "0.4.0-beta.4",
  "description": "NATCA Design System — tokens, components, Vue shell, and shared styles for all NATCA web properties (BETA)",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "main": "dist/vue/natca-ui-shell.js",
  "module": "dist/vue/natca-ui-shell.js",
  "files": [
    "dist/",
    "assets/"
  ],
  "exports": {
    ".": {
      "import": "./dist/vue/natca-ui-shell.js",
      "types": "./dist/vue/index.d.ts"
    },
    "./theme": {
      "import": "./dist/vue/natca-ui-shell.js",
      "types": "./dist/vue/theme/index.d.ts"
    },
    "./tokens": "./dist/natca-tokens.css",
    "./components": "./dist/natca-components.css",
    "./shell-styles": "./dist/vue/natca-ui-shell.css",
    "./scss/settings.scss": "./dist/scss/settings.scss",
    "./theme.json": "./dist/theme.json"
  },
  "scripts": {
    "dev": "vite --config playground/vite.config.ts",
    "build": "npm run build:css && npm run build:vue",
    "build:css": "node build-css.cjs",
    "build:vue": "vite build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "vuetify": "^3.6.0"
  },
  "devDependencies": {
    "@mdi/font": "^7.4.47",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "sass": "^1.99.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vite-plugin-vuetify": "^2.0.3",
    "vue": "^3.5.14",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.2.0",
    "vuetify": "^3.8.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NATCA-ITC/natca-ui-shell.git"
  },
  "keywords": [
    "natca",
    "design-system",
    "tokens",
    "css",
    "ui",
    "vue",
    "vuetify"
  ]
}
